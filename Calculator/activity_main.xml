<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CASIO"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_alignParentEnd="true"
         />

    <EditText
        android:id="@+id/display"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/title"
        android:layout_marginTop="60dp"
        android:hint="0"
        android:gravity="end"
        android:textSize="28sp"
        android:layout_alignParentEnd="true"
        />

    <Button
        android:id="@+id/btn1"
        android:layout_width="60dp"
        android:layout_height="wrap_content"
        android:text="1"
        android:layout_below="@id/display"
        android:layout_marginStart="20sp"
        android:layout_marginLeft="10dp"/>
    <Button
        android:id="@+id/btn2"
        android:layout_width="60dp"
        android:layout_height="wrap_content"
        android:text="2"
        android:layout_marginStart="20sp"
        android:layout_marginLeft="10dp"
        android:layout_toEndOf="@id/btn1"
        android:layout_alignTop="@id/btn1"/>
    <Button
        android:id="@+id/btn3"
        android:layout_width="60dp"
        android:layout_height="wrap_content"
        android:text="3"
        android:layout_marginStart="20sp"
        android:layout_marginLeft="10dp"
        android:layout_toEndOf="@id/btn2"
        android:layout_alignTop="@id/btn2"/>
    <Button
        android:id="@+id/btnplus"
        android:layout_width="110dp"
        android:layout_height="wrap_content"
        android:text="+"
        android:layout_marginStart="40sp"
        android:layout_marginLeft="30dp"
        android:layout_toEndOf="@id/btn3"
        android:layout_alignTop="@id/btn3"/>
    <Button
        android:id="@+id/btn4"
        android:layout_width="60dp"
        android:layout_height="wrap_content"
        android:text="4"
        android:layout_marginStart="20sp"
        android:layout_marginLeft="10dp"
        android:layout_marginTop="20dp"
        android:layout_below="@id/btn1"
        />
    <Button
        android:id="@+id/btn5"
        android:layout_width="60dp"
        android:layout_height="wrap_content"
        android:text="5"
        android:layout_marginStart="20sp"
        android:layout_marginLeft="10dp"
        android:layout_marginTop="20dp"
        android:layout_toEndOf="@id/btn4"
        android:layout_below="@id/btn2"
        />
    <Button
        android:id="@+id/btn6"
        android:layout_width="60dp"
        android:layout_height="wrap_content"
        android:text="6"
        android:layout_marginStart="20sp"
        android:layout_marginLeft="10dp"
        android:layout_marginTop="20dp"
        android:layout_toEndOf="@id/btn5"
        android:layout_below="@id/btn3"
        />
    <Button
        android:id="@+id/btnminuse"
        android:layout_width="110dp"
        android:layout_height="wrap_content"
        android:text="-"
        android:layout_marginStart="40sp"
        android:layout_marginLeft="30dp"
        android:layout_marginTop="20dp"
        android:layout_toEndOf="@id/btn6"
        android:layout_below="@id/btnplus"
        />
    <Button
        android:id="@+id/btn7"
        android:layout_width="60dp"
        android:layout_height="wrap_content"
        android:text="7"
        android:layout_marginStart="20sp"
        android:layout_marginLeft="10dp"
        android:layout_marginTop="20dp"
        android:layout_below="@id/btn4"
        />
    <Button
        android:id="@+id/btn8"
        android:layout_width="60dp"
        android:layout_height="wrap_content"
        android:text="8"
        android:layout_marginStart="20sp"
        android:layout_marginLeft="10dp"
        android:layout_marginTop="20dp"
        android:layout_toEndOf="@id/btn4"
        android:layout_below="@id/btn6"
        />
    <Button
        android:id="@+id/btn9"
        android:layout_width="60dp"
        android:layout_height="wrap_content"
        android:text="9"
        android:layout_marginStart="20sp"
        android:layout_marginLeft="10dp"
        android:layout_marginTop="20dp"
        android:layout_toEndOf="@id/btn8"
        android:layout_below="@id/btn6"
        />
    <Button
        android:id="@+id/btndivide"
        android:layout_width="110dp"
        android:layout_height="wrap_content"
        android:text="/"
        android:layout_marginStart="40sp"
        android:layout_marginLeft="30dp"
        android:layout_marginTop="20dp"
        android:layout_toEndOf="@id/btn9"
        android:layout_below="@id/btnminuse"
        />
    <Button
        android:id="@+id/btnpoint"
        android:layout_width="60dp"
        android:layout_height="wrap_content"
        android:text="."
        android:layout_marginStart="20sp"
        android:layout_marginLeft="10dp"
        android:layout_marginTop="20dp"
        android:layout_below="@id/btn7"
        />
    <Button
        android:id="@+id/btn0"
        android:layout_width="60dp"
        android:layout_height="wrap_content"
        android:text="0"
        android:layout_marginStart="20sp"
        android:layout_marginLeft="10dp"
        android:layout_marginTop="20dp"
        android:layout_toEndOf="@id/btn7"
        android:layout_below="@id/btn8"
        />
    <Button
        android:id="@+id/btnc"
        android:layout_width="60dp"
        android:layout_height="wrap_content"
        android:text="c"
        android:layout_marginStart="20sp"
        android:layout_marginLeft="10dp"
        android:layout_marginTop="20dp"
        android:layout_toEndOf="@id/btn0"
        android:layout_below="@id/btn9"
        />
    <Button
        android:id="@+id/btnmult"
        android:layout_width="110dp"
        android:layout_height="wrap_content"
        android:text="x"
        android:layout_marginStart="40sp"
        android:layout_marginLeft="30dp"
        android:layout_marginTop="20dp"
        android:layout_toEndOf="@id/btn9"
        android:layout_below="@id/btndivide"
        />
    <Button
        android:id="@+id/btnequal"
        android:layout_width="1100dp"
        android:layout_height="wrap_content"
        android:text="="
        android:layout_marginStart="20sp"
        android:layout_marginLeft="10dp"
        android:layout_marginTop="20dp"
        android:layout_below="@id/btnpoint"
        />
</RelativeLayout>